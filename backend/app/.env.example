# Application
DEBUG=True

# Database
# SQLite (default for development)
DATABASE_URL=sqlite:///./cyberduel.db

# PostgreSQL (will be uncommented for production)
# DATABASE_URL=postgresql://user:password@localhost:5432/cyberduel

# Security (CHANGE IN PRODUCTION!)
JWT_SECRET=dev-secret-key-will-be-changed-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]